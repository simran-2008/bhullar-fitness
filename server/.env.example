# =====================================================
#  BHULLAR FITNESS — Environment Variables
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit the real .env file to Git.
# =====================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (MongoDB Atlas) ---
# Get this from Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bhullar-fitness?retryWrites=true&w=majority

# --- JWT ---
# Use a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Email (Nodemailer / Gmail SMTP) ---
# For Gmail, create an "App Password" (not your real password):
#   Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="Bhullar Fitness <youremail@gmail.com>"

# --- Razorpay (online payments) ---
# Dashboard → Settings → API Keys → Generate Key.
# Use the TEST keys (rzp_test_...) while developing; swap to LIVE keys
# (rzp_live_...) only after you've activated the account and tested.
# The KEY_ID is sent to the browser; the KEY_SECRET must stay server-side.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- UPI (QR payments — the primary method) ---
# Your gym's UPI ID (VPA). Members scan a QR built from this with the
# plan amount pre-filled, pay, then submit the UPI reference (UTR) for
# the admin to verify.
UPI_ID=yourgym@upi
UPI_PAYEE_NAME=Bhullar Fitness

# --- CORS ---
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5500,http://127.0.0.1:5500
